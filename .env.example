# Project URL: dashboard → botón "Connect" (o Settings → Data API)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Settings → API Keys → "Publishable key" (sb_publishable_...). La vieja "anon"
# (Legacy API Keys) también funciona.
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY

# Fixed manager account email (created in Supabase Auth). Viewers never see this.
VITE_MANAGER_EMAIL=manager@territorios.local
